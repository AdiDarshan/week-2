#port (FE's default VITE base URL points at http://localhost:3001)
PORT=3001

#allowed cors origins, comma-separated (Vite dev server default)
ALLOWED_CORS_ORIGINS=http://localhost:5173

#secret used to sign JWT access tokens (min 16 chars). use a long random string in real envs.
JWT_SECRET=replace-me-with-a-long-random-string

# MongoDB connection string. Include the database name as the path segment.
# Sending a message uses a multi-document transaction (insert message +
# update conversation.lastMessageAt atomically), which requires a replica set.
# Local setup: add `replication:\n  replSetName: rs0` to mongod.conf, restart
# mongod, then run `mongosh --eval "rs.initiate()"` once.
# MongoDB Atlas free tier works out of the box (already a replica set).
MONGO_URI=mongodb://localhost:27017/chat-app

# OpenAI API key — required by LanguageModelService
OPENAI_API_KEY=your-openai-api-key-here
