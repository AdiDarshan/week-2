{
  "name": "week-2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/frontend",
    "dev:backend": "npm run dev --workspace apps/backend",
    "dev:backend-nest": "npm run dev --workspace apps/backend-nest",
    "build": "npm run build --workspaces --if-present",
    "preview": "npm run preview --workspace apps/frontend",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspace apps/frontend",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "dependencies": {
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "mongoose": "^9.7.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1"
  },
  "allowScripts": {
    "@nestjs/mongoose@11.0.4": true
  }
}
